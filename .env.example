# Gemini Vision API Key (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Text, code, chart assistant)
GROQ_API_KEY=your_groq_api_key_here

# Optional model overrides
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_BACKUP_MODEL=gemini-2.0-flash
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_BACKUP_MODEL=llama-3.1-8b-instant
GROQ_CODE_MODEL=qwen/qwen3.6-27b

# Legacy FastAPI backend config. Tab 6 no longer depends on this flow.
BACKEND_PORT=8000
BACKEND_HOST=http://localhost:8000
